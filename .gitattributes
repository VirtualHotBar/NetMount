# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare source files to use LF line endings
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.less text eol=lf
*.md text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Shell scripts should use LF
*.sh text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Build artifacts and binaries should not be normalized
*.exe -text
*.dll -text
*.so -text
*.dylib -text
*.pdf -text
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
*.svg -text
*.woff -text
*.woff2 -text
*.ttf -text
*.eot -text
